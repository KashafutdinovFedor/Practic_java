4)Побитовые и логические операторы

    int i = 5;  // 0101 в двоичной системе
    int j = 3;  // 0011 в двоичной системе

    // Побитовые: & (И), ^ (Исключающее ИЛИ), | (ИЛИ), ~ (Инверсия)
    int and = i & j; // 0001 (1)
    int xor = i ^ j; // 0110 (6)
    int or  = i | j; // 0111 (7)
    int inv = ~i;    // Инвертирует все биты

    // Логические: && (И), || (ИЛИ), ! (НЕ)
    boolean cond = (i > 0) && (j < 10); // true
    boolean notVal = !(i == j);         // true

5)Битовые сдвиги

    int val = 8; // 1000

    int shiftLeft = val << 1;  // 16 (сдвиг влево, умножение на 2)
    int shiftRight = val >> 1; // 4 (сдвиг вправо с сохранением знака)
    int unsignedRight = val >>> 1; // 4 (сдвиг вправо с заполнением нулями)

