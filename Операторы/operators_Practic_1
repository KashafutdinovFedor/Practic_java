2)Инкремент и декремент
    int x = 5;

    // Постфиксная форма: сначала используется значение, потом меняется
    System.out.println(x++); // Выведет 5, но x станет 6
    System.out.println(x--); // Выведет 6, но x станет 5

    // Префиксная форма: сначала меняется значение, потом используется
    System.out.println(++x); // x станет 6, выведет 6
    System.out.println(--x); // x станет 5, выведет 5


